{
  "$schema": "https://raw.githubusercontent.com/GoogleChrome/lighthouse-ci/main/docs/configuration.md",
  "ci": {
    "collect": {
      "startServerCommand": "node apps/site/.next/standalone/apps/site/server.js",
      "startServerReadyPattern": "Ready",
      "startServerReadyTimeout": 60000,
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/stages",
        "http://localhost:3000/stages/fundamentos",
        "http://localhost:3000/library",
        "http://localhost:3000/glossary"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--headless=new --no-sandbox"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "color-contrast": "error",
        "image-alt": "error",
        "html-has-lang": "error",
        "meta-description": "warn"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
