#!/usr/bin/env sh
# Pre-commit hook — roda validation script.
# Catch typos e prereq references quebradas antes do CI.
#
# Pra ativar:
#   git config core.hooksPath .githooks
#
# Pra pular pontualmente:
#   git commit --no-verify

set -e

echo "[pre-commit] running content validation…"
node scripts/validate-content.mjs --quiet
echo "[pre-commit] ok"
